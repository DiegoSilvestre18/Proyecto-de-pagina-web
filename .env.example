# Copia este archivo a .env antes de levantar docker compose
POSTGRES_DB=db_proyecto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTE_PASSWORD_DB_EN_PRODUCCION

# Usa una clave larga y aleatoria en producción
JWT_KEY=CAMBIA_ESTA_CLAVE_POR_UNA_SUPER_SECRETA_DE_AL_MENOS_64_CARACTERES

# CORS para backend (dominios que podrán llamar a la API)
CORS_ORIGIN_1=https://arenagamergg.com
CORS_ORIGIN_2=https://www.arenagamergg.com

# Defaults para mismo dominio con Nginx proxy
# Si tu dominio es https://arenagamergg.com, puedes dejar estos valores así
# o usar explícitamente:
# VITE_API_URL=https://arenagamergg.com
# VITE_SIGNALR_URL=https://arenagamergg.com/salahub
VITE_API_URL=/
VITE_SIGNALR_URL=/salahub
